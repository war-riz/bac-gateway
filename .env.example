# ================================================================
#  Copy this file to .env and fill in YOUR real values.
#  The app reads from .env automatically — never hardcoded.
#  NEVER commit .env to Git.
# ================================================================

# App
APP_NAME="BAC Security Gateway"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# MongoDB Atlas — paste your full connection string here
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=bac_gateway

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gateway
PROTECTED_APP_URL=http://localhost:5000
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Admin account (auto-created on first run)
ADMIN_EMAIL=admin@bacgateway.com
ADMIN_PASSWORD=Admin@123456
ADMIN_USERNAME=admin

# Email (for vulnerable site — use Gmail App Password or Mailtrap for dev)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=ScholarPortal <your-email@gmail.com>
